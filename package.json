{
	"name": "kozz-gw",
	"version": "1.0.0",
	"description": "Gateway for Kozz Bot",
	"main": "./dist/index.js",
	"license": "MIT",
	"scripts": {
		"dev": "tsc && link-module-alias && tsc --watch & nodemon dist/index.js",
		"start": "tsc && link-module-alias && node dist/index.js",
		"web:dev": "vite --host 0.0.0.0 --config panel/vite.config.ts",
		"web:build": "vite build --config panel/vite.config.ts",
		"panel:sign": "node ./scripts/panel_signature.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"docs": "typedoc ./src/index.ts",
		"build": "tsc",
		"build:lib": "tsc ./scr/lib.ts"
	},
	"devDependencies": {
		"@types/express": "^4.17.21",
		"@types/jest": "^29.5.14",
		"concurrently": "^7.6.0",
		"kozz-types": "^0.2.0",
		"nodemon": "^3.1.9",
		"parcel": "^2.13.3",
		"process": "^0.11.10",
		"typedoc": "^0.23.28",
		"typescript": "^4.9.5",
		"vitest": "^2.1.9"
	},
	"dependencies": {
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/state": "^6.7.1",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.43.6",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@uiw/react-codemirror": "^4.25.11",
		"@vitejs/plugin-react": "^6.0.3",
		"arcsecond": "^5.0.0",
		"axios": "^1.7.9",
		"cors": "^2.8.5",
		"express": "^4.21.2",
		"keytar": "^7.9.0",
		"kozz-module-maker": "^0.4.0",
		"link-module-alias": "^1.2.0",
		"lucide-react": "^1.24.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"socket.io": "^4.8.1",
		"socket.io-client": "^4.8.3",
		"vite": "^8.1.5",
		"zod": "^3.25.76"
	},
	"_moduleAliases": {
		"src": "dist"
	}
